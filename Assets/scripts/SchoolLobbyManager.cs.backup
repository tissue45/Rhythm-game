    private void CreateSongCard(Transform parent, string title, bool unlock, int index)
    {
        if (parent == null) return;

        // Cover Flow Card (Square)
        GameObject card = new GameObject("SongCard_" + title);
        card.layer = LayerMask.NameToLayer("UI");
        card.transform.SetParent(parent, false);

        // Card Background (Album Art Container)
        UnityEngine.UI.Image img = card.AddComponent<UnityEngine.UI.Image>();
        img.color = unlock ? Color.white : new Color(0.1f, 0.1f, 0.1f, 0.8f); 
        
        // [FIX] Preserve Aspect Ratio to prevent "Cutting off" / Squashing
        img.preserveAspect = true;
        
        // [FIX] Assign Album Art
        if (unlock && albumCovers != null && index < albumCovers.Length && albumCovers[index] != null)
        {
             img.sprite = albumCovers[index];
        }

        RectTransform rt = card.GetComponent<RectTransform>();
        rt.sizeDelta = new Vector2(320, 320); 
        rt.localScale = Vector3.one;
        // [FIX] Offset UP to separate from bottom text, even if container expands down
        rt.anchoredPosition = new Vector2(0, 80);

        // Overlay for Lock
        if(!unlock)
        {
            GameObject lockOverlay = new GameObject("LockOverlay");
            lockOverlay.transform.SetParent(card.transform, false);
            var lockImg = lockOverlay.AddComponent<UnityEngine.UI.Image>();
            lockImg.color = new Color(0, 0, 0, 0.6f);
            
            RectTransform lrt = lockOverlay.GetComponent<RectTransform>();
            lrt.anchorMin = Vector2.zero; lrt.anchorMax = Vector2.one;
            lrt.sizeDelta = Vector2.zero;
            
            GameObject lockTxtObj = new GameObject("LockText");
            lockTxtObj.transform.SetParent(lockOverlay.transform, false);
            var lTxt = lockTxtObj.AddComponent<TMPro.TextMeshProUGUI>();
            lTxt.text = "LOCKED";
            lTxt.fontSize = 40;
            lTxt.alignment = TMPro.TextAlignmentOptions.Center;
            lTxt.color = Color.gray;
        }

        // Title Text (Below Card)
        GameObject txtObj = new GameObject("Title");
        txtObj.transform.SetParent(card.transform, false);
        var txt = txtObj.AddComponent<TMPro.TextMeshProUGUI>();
        txt.text = title.ToUpper();
        txt.alignment = TMPro.TextAlignmentOptions.Center; 
        txt.fontSize = 32;
        txt.fontStyle = TMPro.FontStyles.Bold;
        txt.color = Color.white;
        
        // Shadow
        var outline = txtObj.AddComponent<UnityEngine.UI.Outline>();
        outline.effectColor = new Color(0,0,0,0.8f);
        outline.effectDistance = new Vector2(2, -2);
        
        RectTransform txtRt = txtObj.GetComponent<RectTransform>();
        // [FIX] Move text closer to image to avoid overlap with bottom button
        txtRt.anchorMin = new Vector2(0, -0.15f); txtRt.anchorMax = new Vector2(1, 0); 
        txtRt.offsetMin = Vector2.zero; txtRt.offsetMax = Vector2.zero;

        // Button Logic (Click to Select)
        UnityEngine.UI.Button btn = card.AddComponent<UnityEngine.UI.Button>();
        // Invisible button over the art
        UnityEngine.UI.ColorBlock cb = btn.colors;
        cb.highlightedColor = new Color(1,1,1,1.1f); // Slight brighten
        btn.colors = cb;

        btn.onClick.AddListener(() => {
            // Snap Carousel
            var cv = parent.GetComponentInParent<CarouselView>();
            if (cv != null) cv.SnapTo(index);
        });
    }

    private void PopulateSongSelect(GameObject panel)
    {
        Debug.Log($"[Lobby] Layout: Cover Flow Mode");

        foreach (Transform child in panel.transform) Destroy(child.gameObject);

        // 1. Background (Dark Overlay)
        var bgImg = panel.GetComponent<UnityEngine.UI.Image>();
        if(bgImg == null) bgImg = panel.AddComponent<UnityEngine.UI.Image>();
        bgImg.color = new Color(0, 0, 0, 0.85f); // Slightly transparent

        // 2. Carousel Container (Full Width, Centered)
        GameObject carouselPanel = new GameObject("CoverFlowContainer");
        carouselPanel.transform.SetParent(panel.transform, false);
        RectTransform cRt = carouselPanel.AddComponent<RectTransform>();
        // [FIX] Expand range DOWN (0.15) to unmask text, but keep cards high (via offset)
        cRt.anchorMin = new Vector2(0, 0.15f); cRt.anchorMax = new Vector2(1, 1f); 
        cRt.offsetMin = Vector2.zero; cRt.offsetMax = new Vector2(0, -20);

        // Scroll Rect
        var scroll = carouselPanel.AddComponent<UnityEngine.UI.ScrollRect>();
        carouselPanel.AddComponent<UnityEngine.UI.Image>().color = Color.clear;
        
        // Viewport
        GameObject viewport = new GameObject("Viewport");
        viewport.transform.SetParent(carouselPanel.transform, false);
        RectTransform vRt = viewport.AddComponent<RectTransform>();
        vRt.anchorMin = Vector2.zero; vRt.anchorMax = Vector2.one;
        vRt.sizeDelta = Vector2.zero;
        viewport.AddComponent<UnityEngine.UI.RectMask2D>();
        scroll.viewport = vRt;

        // Content
        GameObject contentObj = new GameObject("Content");
        contentObj.transform.SetParent(viewport.transform, false);
        var contentRt = contentObj.AddComponent<RectTransform>();
        // Size determined by items, simpler to set huge width
        contentRt.sizeDelta = new Vector2(2000, 600); 
        scroll.content = contentRt;
        scroll.horizontal = true; scroll.vertical = false; // [FIX] Horizontal
        scroll.movementType = UnityEngine.UI.ScrollRect.MovementType.Elastic;
        scroll.inertia = true; scroll.decelerationRate = 0.135f;

        // Carousel View Logic
        var cv = carouselPanel.AddComponent<CarouselView>();
        cv.container = contentRt;
        cv.spacing = 400f; // Adjusted spacing
        cv.scaleFactor = 1.2f; // [FIX] Reduced scale slightly (was 1.3)
        cv.scaleSpeed = 8f;
        cv.isVertical = false; // Horizontal

        // Items
        string[] songs = { "GALAXIAS!", "SODAPOP", "Coming Soon" };
        for(int i=0; i<songs.Length; i++)
        {
            CreateSongCard(contentRt, songs[i], i <= 1, i);
        }

        // 3. Game Start Button (Bottom Center)
        GameObject startBtnObj = new GameObject("Btn_StartGame");
        startBtnObj.transform.SetParent(panel.transform, false);
        
        // Style
        var startImg = startBtnObj.AddComponent<UnityEngine.UI.Image>();
        startImg.color = new Color(0, 0.8f, 1f); // Cyan
        var startBtn = startBtnObj.AddComponent<UnityEngine.UI.Button>(); 
        // [FIX] Removed ApplyButtonStyle as per user request (Style looks weird centered)
        
        RectTransform startRt = startBtnObj.GetComponent<RectTransform>();
        // [FIX] Lower the button slightly to give more room
        startRt.anchorMin = new Vector2(0.35f, 0.02f); startRt.anchorMax = new Vector2(0.65f, 0.12f);
        startRt.offsetMin = Vector2.zero; startRt.offsetMax = Vector2.zero;
        
        // Button Text
        GameObject stTxtObj = new GameObject("Text");
        stTxtObj.transform.SetParent(startBtnObj.transform, false);
        var stTxt = stTxtObj.AddComponent<TMPro.TextMeshProUGUI>();
        stTxt.text = "GAME START";
        stTxt.fontSize = 36;
        stTxt.alignment = TMPro.TextAlignmentOptions.Center;
        stTxt.color = Color.black; 
        stTxt.fontStyle = TMPro.FontStyles.Bold;
        
        var stRt = stTxtObj.GetComponent<RectTransform>();
        stRt.anchorMin = Vector2.zero; stRt.anchorMax = Vector2.one;
        stRt.offsetMin = Vector2.zero; stRt.offsetMax = Vector2.zero;

        // Button Action
        startBtn.onClick.AddListener(()=> { 
            Debug.Log($"[Lobby] Validating Selection: {_selectedSongTitle}");
            
            // Check Lock
            if (_selectedSongTitle.Contains("Locked") || _selectedSongTitle == "Coming Soon") {
                 Debug.Log("[Lobby] Song is LOCKED.");
                 return;
            }

            // [NEW] Play Mode Selection Popup
            GameObject modePopup = new GameObject("ModeSelectionPopup");
            modePopup.transform.SetParent(panel.transform.parent, false); // Add to Canvas, overlaying everything
            
            // Full Screen Dimmer
            var dim = modePopup.AddComponent<UnityEngine.UI.Image>();
            dim.color = new Color(0,0,0,0.8f);
            var dimRt = modePopup.GetComponent<RectTransform>();
            dimRt.anchorMin = Vector2.zero; dimRt.anchorMax = Vector2.one;
            dimRt.offsetMin = Vector2.zero; dimRt.offsetMax = Vector2.zero;
            
            // Container
            GameObject container = new GameObject("Container");
            container.transform.SetParent(modePopup.transform, false);
            var cImg = container.AddComponent<UnityEngine.UI.Image>();
            cImg.color = new Color(0.1f, 0.1f, 0.15f);
            var cRt = container.GetComponent<RectTransform>();
            cRt.sizeDelta = new Vector2(600, 400);
            
            // Title
            GameObject titleObj = new GameObject("Title");
            titleObj.transform.SetParent(container.transform, false);
            var tTxt = titleObj.AddComponent<TMPro.TextMeshProUGUI>();
            tTxt.text = "SELECT PLAY MODE";
            tTxt.fontSize = 36; tTxt.alignment = TMPro.TextAlignmentOptions.Center;
            tTxt.fontStyle = TMPro.FontStyles.Bold;
            tTxt.color = Color.cyan;
            var tRt = titleObj.GetComponent<RectTransform>();
            tRt.anchorMin = new Vector2(0, 0.8f); tRt.anchorMax = new Vector2(1, 1);
            tRt.offsetMin = Vector2.zero; tRt.offsetMax = Vector2.zero;

            // PC Button
            GameObject pcBtnObj = new GameObject("Btn_PC");
            pcBtnObj.transform.SetParent(container.transform, false);
            var pcImg = pcBtnObj.AddComponent<UnityEngine.UI.Image>();
            pcImg.color = new Color(0.2f, 0.6f, 1f);
            var pcBtn = pcBtnObj.AddComponent<UnityEngine.UI.Button>();
            var pcRt = pcBtnObj.GetComponent<RectTransform>();
            pcRt.anchorMin = new Vector2(0.1f, 0.3f); pcRt.anchorMax = new Vector2(0.45f, 0.6f);
            pcRt.offsetMin = Vector2.zero; pcRt.offsetMax = Vector2.zero;
            
            GameObject pcTxtObj = new GameObject("Text");
            pcTxtObj.transform.SetParent(pcBtnObj.transform, false);
            var pcTxt = pcTxtObj.AddComponent<TMPro.TextMeshProUGUI>();
            pcTxt.text = "COMPUTER\n(Keyboard)";
            pcTxt.fontSize = 24; pcTxt.alignment = TMPro.TextAlignmentOptions.Center;
            
            pcBtn.onClick.AddListener(() => {
                Debug.Log("[Mode] Computer Selected.");
                Destroy(modePopup);
                StartGameLoop();
            });

            // Mobile Button
            GameObject mbBtnObj = new GameObject("Btn_Mobile");
            mbBtnObj.transform.SetParent(container.transform, false);
            var mbImg = mbBtnObj.AddComponent<UnityEngine.UI.Image>();
            mbImg.color = new Color(1f, 0.4f, 0.8f);
            var mbBtn = mbBtnObj.AddComponent<UnityEngine.UI.Button>();
            var mbRt = mbBtnObj.GetComponent<RectTransform>();
            mbRt.anchorMin = new Vector2(0.55f, 0.3f); mbRt.anchorMax = new Vector2(0.9f, 0.6f);
            mbRt.offsetMin = Vector2.zero; mbRt.offsetMax = Vector2.zero;
            
            GameObject mbTxtObj = new GameObject("Text");
            mbTxtObj.transform.SetParent(mbBtnObj.transform, false);
            var mbTxt = mbTxtObj.AddComponent<TMPro.TextMeshProUGUI>();
            mbTxt.text = "MOBILE\n(Controller)";
            mbTxt.fontSize = 24; mbTxt.alignment = TMPro.TextAlignmentOptions.Center;
            
            mbBtn.onClick.AddListener(() => {
                Debug.Log("[Mode] Mobile Selected. Opening QR.");
                Destroy(modePopup);
                TogglePanel(qrConnectionPanel); // Open QR Panel
            });

            // Close X (Styled)
            GameObject closeObj = new GameObject("Close");
            closeObj.transform.SetParent(container.transform, false);
            var clBtn = closeObj.AddComponent<UnityEngine.UI.Button>();
            var clImg = closeObj.AddComponent<UnityEngine.UI.Image>(); 
            clImg.color = new Color(0,0,0,0); // Transparent
            
            var clRt = closeObj.GetComponent<RectTransform>();
            clRt.anchorMin = new Vector2(0.92f, 0.9f); clRt.anchorMax = new Vector2(0.98f, 0.98f); // Top Right corner
            clRt.offsetMin = Vector2.zero; clRt.offsetMax = Vector2.zero;
            
            // Text for X
            GameObject clTxtObj = new GameObject("Text");
            clTxtObj.transform.SetParent(closeObj.transform, false);
            var clTxt = clTxtObj.AddComponent<TMPro.TextMeshProUGUI>();
            clTxt.text = "X";
            clTxt.fontSize = 28;
            clTxt.alignment = TMPro.TextAlignmentOptions.Center;
            clTxt.color = Color.white;
            
            // Hover Color Block
            UnityEngine.UI.ColorBlock cb = clBtn.colors;
            cb.highlightedColor = new Color(1f, 0, 0, 0.5f); // Red tint on hover
            cb.pressedColor = new Color(0.8f, 0, 0, 0.5f);
            clBtn.colors = cb;

            clBtn.onClick.AddListener(() => Destroy(modePopup));
        });

        // 4. Close Button (Top Right)
        GameObject closeBtnObj = new GameObject("Btn_Close");
        closeBtnObj.transform.SetParent(panel.transform, false);
        var closeImg = closeBtnObj.AddComponent<UnityEngine.UI.Image>();
        closeImg.color = new Color(1f, 1f, 1f, 0f); // Invisible hit area
        var closeBtn = closeBtnObj.AddComponent<UnityEngine.UI.Button>();
        closeBtn.onClick.AddListener(() => { TogglePanel(panel); });
        
        // Visual X
        GameObject xObj = new GameObject("X");
        xObj.transform.SetParent(closeBtnObj.transform, false);
        var xTxt = xObj.AddComponent<TMPro.TextMeshProUGUI>();
        xTxt.text = "X"; xTxt.fontSize = 40; xTxt.color = Color.white;
        xTxt.alignment = TMPro.TextAlignmentOptions.Center;
        
        RectTransform closeRt = closeBtnObj.GetComponent<RectTransform>();
        closeRt.anchorMin = new Vector2(0.92f, 0.92f); closeRt.anchorMax = new Vector2(0.98f, 0.98f);
        closeRt.sizeDelta = Vector2.zero;
        
        RectTransform xRt = xObj.GetComponent<RectTransform>();
        xRt.anchorMin = Vector2.zero; xRt.anchorMax = Vector2.one;
        xRt.sizeDelta = Vector2.zero;


        // Selection Callback
        cv.Invoke("InitializeItems", 0.1f);
        cv.OnItemSelected = (index) => {
            if (index >= 0 && index < songs.Length)
            {
                string s = songs[index];
                _selectedSongTitle = s;
                Debug.Log($"[Carousel] Selected: {s}");
                
                // Optional: Update BG color or effects based on song
                // [FIX] LOCK LOGIC
                bool isLocked = (s == "Coming Soon" || s.Contains("Locked"));
                startBtn.interactable = !isLocked;
                stTxt.text = isLocked ? "LOCKED" : "GAME START";

                startImg.color = isLocked ? Color.gray : new Color(0, 0.7f, 0.9f);

                stTxt.color = isLocked ? new Color(0.3f, 0.3f, 0.3f) : Color.black;

            }

        };

    }





    private void BindSongSelectStartButton(GameObject panel)

    {

        // "StartButton" ???"Btn_Start" ì°¾ê¸°

        var buttons = panel.GetComponentsInChildren<UnityEngine.UI.Button>(true);

        UnityEngine.UI.Button startBtn = null;

        

        foreach (var btn in buttons)

        {

            if (btn.name.Contains("Start") || btn.name.Contains("Play") || 

                btn.GetComponentInChildren<TMPro.TextMeshProUGUI>()?.text.ToUpper().Contains("START") == true ||

                btn.GetComponentInChildren<TMPro.TextMeshProUGUI>()?.text.ToUpper().Contains("PLAY") == true)

            {

                startBtn = btn;

                break;

            }

        }



        if (startBtn != null)

        {

            startBtn.onClick.RemoveAllListeners();

            startBtn.onClick.AddListener(() => {

                StartGameLoop();

            });

            Debug.Log("[SchoolLobbyManager] Bound Song Select START button!");

        }

        else

        {

            Debug.LogWarning("[SchoolLobbyManager] Could NOT find Start Button in Song Select Panel!");

        }

    }







    private void CloseAllPanels()

    {

        if (songSelectPanel != null) songSelectPanel.SetActive(false);

        if (rankingPanel != null) rankingPanel.SetActive(false);

        if (shopPanel != null) shopPanel.SetActive(false);

        if (profilePanel != null) profilePanel.SetActive(false);

        if (optionsPanel != null) optionsPanel.SetActive(false);

        if (customizationPanel != null) customizationPanel.SetActive(false);

    }



    private void UpdateProfileUI()
    {
        Debug.Log("[Lobby] Updating Profile UI...");
        
        // Find or Create Welcome Text
        GameObject welcomeObj = GameObject.Find("WelcomeText");
        
        if (NetworkManager.Instance.IsLoggedIn)
        {
             if (welcomeObj == null)
             {
                 // Create in Top-Right
                 welcomeObj = new GameObject("WelcomeText");
                 GameObject canvas = GameObject.Find("Canvas");
                 if(canvas) welcomeObj.transform.SetParent(canvas.transform, false);
                 
                 var txt = welcomeObj.AddComponent<TMPro.TextMeshProUGUI>();
                 txt.fontSize = 24;
                 txt.alignment = TMPro.TextAlignmentOptions.Right;
                 txt.color = Color.cyan;
                 
                 RectTransform rt = welcomeObj.GetComponent<RectTransform>();
                 rt.anchorMin = new Vector2(1, 1); rt.anchorMax = new Vector2(1, 1);
                 rt.pivot = new Vector2(1, 1);
                 rt.anchoredPosition = new Vector2(-20, -120); // Below logo
                 rt.sizeDelta = new Vector2(400, 50);
             }
             
             var wTxt = welcomeObj.GetComponent<TMPro.TextMeshProUGUI>();
             
             // Get Name if available, else Email
             NetworkManager.Instance.GetUserProfile((profile) => {
                 string displayName = "Player";
                 if (profile != null && !string.IsNullOrEmpty(profile.name)) displayName = profile.name;
                 else if (!string.IsNullOrEmpty(NetworkManager.Instance.CurrentUserEmail)) displayName = NetworkManager.Instance.CurrentUserEmail.Split('@')[0];
                 
                 wTxt.text = $"Welcome, {displayName}!";
                 
                 // Also hide Login Button from Footer if exists
                 GameObject loginBtn = GameObject.Find("Btn_Login");
                 if (loginBtn) loginBtn.SetActive(false);
             });
        }
    }

    private void BindCloseButton(GameObject panel)

    {

        // ???????"CloseButton" ?ë¦??ê°?ë²í¼ ì°¾ê¸° (?????

        // ë§ì½ ?ë¦??"Close"?ë©?"Close"?ì°¾ì¼??? ë³´íµ "CloseButton"???"Btn_Close" ??????????

        // ?ê¸???"CloseButton" ???"Btn_Close" ?????????

        

        UnityEngine.UI.Button closeBtn = panel.GetComponentInChildren<UnityEngine.UI.Button>(); // ????ë¬?ë²í¼????????????(ë³´íµ ?ê¸???ë¿???????

        

        // ?ë¦?ë¡?????ì°¾ê³  ???

        UnityEngine.UI.Button[] allBtns = panel.GetComponentsInChildren<UnityEngine.UI.Button>(true);

        foreach (var btn in allBtns)

        {

            if (btn.name.Contains("Close") || btn.name.Contains("Exit") || btn.transform.Find("Text (TMP)")?.GetComponent<TMPro.TextMeshProUGUI>()?.text.Contains("CLOSE") == true)

            {

                closeBtn = btn;

                break;

            }

        }



        if (closeBtn != null)

        {

            // ?ê¸?ë²í¼?????? ?ë¦??ë§? ?ê²????
            var txt = closeBtn.GetComponentInChildren<TMPro.TextMeshProUGUI>();

            if (txt != null) txt.raycastTarget = false;

            var txt2 = closeBtn.GetComponentInChildren<UnityEngine.UI.Text>();

            if (txt2 != null) txt2.raycastTarget = false;



            // ?ë²???ê²?
            closeBtn.onClick.RemoveAllListeners();

            closeBtn.onClick.AddListener(() => {

                panel.SetActive(false);

                Debug.Log($"[SchoolLobbyManager] Closed panel: {panel.name}");

            });

            Debug.Log($"[SchoolLobbyManager] Bound Close Button in {panel.name}");

        }

        else

        {

            Debug.LogWarning($"[SchoolLobbyManager] Could NOT find Close Button in {panel.name}");

        }

    }





    // [NEW] Helper to find inactive objects recursively

    private GameObject FindObjectRecursive(GameObject root, string name)

    {

        if (root == null) return null;

        if (root.name == name) return root;

        

        foreach(Transform t in root.transform)

        {

            if (t.name == name) return t.gameObject;

            GameObject res = FindObjectRecursive(t.gameObject, name);

            if (res != null) return res;

        }

        return null;

    }



    private void PopulateRanking(GameObject panel)

    {

        Debug.Log("[Lobby] Populating Ranking...");



        foreach (Transform child in panel.transform) Destroy(child.gameObject);



        // Title

        GameObject titleObj = new GameObject("Title");

        titleObj.transform.SetParent(panel.transform, false);

        var titleTxt = titleObj.AddComponent<TMPro.TextMeshProUGUI>();

        titleTxt.text = "RANKING";

        titleTxt.fontSize = 50;

        titleTxt.fontStyle = TMPro.FontStyles.Bold;

        titleTxt.alignment = TMPro.TextAlignmentOptions.Center;

        titleTxt.color = Color.white;

        RectTransform titleRt = titleObj.GetComponent<RectTransform>();

        titleRt.anchorMin = new Vector2(0, 0.85f); titleRt.anchorMax = new Vector2(1, 1);

        titleRt.offsetMin = Vector2.zero; titleRt.offsetMax = Vector2.zero;



        // Container (Scroll View)

        GameObject scrollObj = new GameObject("ScrollArea");

        scrollObj.transform.SetParent(panel.transform, false);

        var scrollRt = scrollObj.AddComponent<RectTransform>();

        scrollRt.anchorMin = new Vector2(0.1f, 0.1f); scrollRt.anchorMax = new Vector2(0.9f, 0.8f);

        scrollRt.offsetMin = Vector2.zero; scrollRt.offsetMax = Vector2.zero;

        

        scrollObj.AddComponent<UnityEngine.UI.Image>().color = new Color(0,0,0,0.5f);

        var scroll = scrollObj.AddComponent<UnityEngine.UI.ScrollRect>();

        

        GameObject content = new GameObject("Content");

        content.transform.SetParent(scrollObj.transform, false);

        var vlg = content.AddComponent<UnityEngine.UI.VerticalLayoutGroup>();

        vlg.padding = new RectOffset(20, 20, 20, 20);

        vlg.spacing = 15;

        vlg.childControlHeight = false; vlg.childControlWidth = true;

        vlg.childAlignment = TextAnchor.UpperCenter;

        

        var csf = content.AddComponent<UnityEngine.UI.ContentSizeFitter>();

        csf.verticalFit = UnityEngine.UI.ContentSizeFitter.FitMode.PreferredSize;



        scroll.content = content.GetComponent<RectTransform>();

        scroll.vertical = true; scroll.horizontal = false;

        scroll.movementType = UnityEngine.UI.ScrollRect.MovementType.Elastic;



        // Viewport Mask

        GameObject viewport = new GameObject("Viewport");

        viewport.transform.SetParent(scrollObj.transform, false);

        viewport.AddComponent<UnityEngine.UI.RectMask2D>();

        var vpRt = viewport.GetComponent<RectTransform>();

        vpRt.anchorMin = Vector2.zero; vpRt.anchorMax = Vector2.one;

        vpRt.offsetMin = Vector2.zero; vpRt.offsetMax = Vector2.zero;

        scroll.viewport = vpRt;

        content.transform.SetParent(viewport.transform, false);



        // Mock Data Fallback
        string[] names = { "RhythmKing", "ProGamer_KR", "SodapopLover" };
        int[] scores = { 1000000, 985000, 950000 };
        
        // [NEW] Fetch from Network
        if (NetworkManager.Instance != null)
        {
             NetworkManager.Instance.GetRanking((json) => {
                 if (!string.IsNullOrEmpty(json))
                 {
                     Debug.Log($"[Ranking] Received: {json}");
                     try {
                         // Parse Real Data
                         RankEntry[] entries = JsonHelper.FromJson<RankEntry>(json);
                         
                         // Clear Mock items if any (though we clear at start)
                         foreach(Transform t in content.transform) Destroy(t.gameObject);

                         if(entries == null || entries.Length == 0) {
                             CreateRankItem(content.transform, 0, "No Data", 0);
                         } 
                         else 
                         {
                             for(int i=0; i<entries.Length; i++)
                             {
                                 CreateRankItem(content.transform, i, entries[i].username, entries[i].score);
                             }
                         }
                         return; // Successfully populated
                     } catch (System.Exception e) {
                         Debug.LogError("Rank Parse Error: " + e.Message);
                     }
                 }
                 
                 // Fallback if failed
                 CreateMockRanking(content.transform, names, scores);
             });
        }
        else
        {
             CreateMockRanking(content.transform, names, scores);
        }

        // Close Button logic remains...
        GameObject closeBtnObj = new GameObject("Btn_Close");

        closeBtnObj.transform.SetParent(panel.transform, false);

        var closeImg = closeBtnObj.AddComponent<UnityEngine.UI.Image>();

        closeImg.color = new Color(0.2f, 0.2f, 0.2f, 0.8f);

        var closeBtn = closeBtnObj.AddComponent<UnityEngine.UI.Button>();

        closeBtn.onClick.AddListener(() => { TogglePanel(panel); });

        

        RectTransform closeRt = closeBtnObj.GetComponent<RectTransform>();

        closeRt.anchorMin = new Vector2(0.92f, 0.92f); closeRt.anchorMax = new Vector2(0.98f, 0.98f);

        closeRt.offsetMin = Vector2.zero; closeRt.offsetMax = Vector2.zero;

        

        GameObject closeTxtObj = new GameObject("Text");

        closeTxtObj.transform.SetParent(closeBtnObj.transform, false);

        var clTxt = closeTxtObj.AddComponent<TMPro.TextMeshProUGUI>();

        clTxt.text = "X";

        clTxt.fontSize = 28;

        clTxt.alignment = TMPro.TextAlignmentOptions.Center;

        clTxt.color = Color.white;

        

        var clRt = closeTxtObj.AddComponent<RectTransform>();

        clRt.anchorMin = Vector2.zero; clRt.anchorMax = Vector2.one;

        clRt.offsetMin = Vector2.zero; clRt.offsetMax = Vector2.zero;

    }



    // [NEW] Helper classes
    
    private void CreateMockRanking(Transform content, string[] names, int[] scores)
    {
        for(int i=0; i<names.Length; i++)
        {
            CreateRankItem(content, i, names[i], scores[i]);
        }
    }

    private void CreateRankItem(Transform content, int i, string name, int score)
    {
        GameObject item = new GameObject($"Rank_{i}");
        item.transform.SetParent(content, false);
            
        var hlg = item.AddComponent<UnityEngine.UI.HorizontalLayoutGroup>();
        hlg.padding = new RectOffset(20, 20, 5, 5);
        hlg.spacing = 20;
        hlg.childControlWidth = false; hlg.childControlHeight = false;
        hlg.childAlignment = TextAnchor.MiddleLeft;

        var bgImg = item.AddComponent<UnityEngine.UI.Image>();
        bgImg.color = new Color(0,0,0,0.5f);

        var le = item.AddComponent<UnityEngine.UI.LayoutElement>();
        le.preferredHeight = 80;

        if (i < 3)
        {
             GameObject medalObj = new GameObject("Medal");
             medalObj.transform.SetParent(item.transform, false);
             var mImg = medalObj.AddComponent<UnityEngine.UI.Image>();
             if(i==0) mImg.color = new Color(1f, 0.8f, 0.2f);
             else if(i==1) mImg.color = new Color(0.8f, 0.8f, 0.9f);
             else if(i==2) mImg.color = new Color(0.8f, 0.5f, 0.2f);
             var mLe = medalObj.AddComponent<UnityEngine.UI.LayoutElement>();
             mLe.preferredWidth = 50; mLe.preferredHeight = 50;
        }
        else
        {
             GameObject spacer = new GameObject("Spacer");
             spacer.transform.SetParent(item.transform, false);
             var sLe = spacer.AddComponent<UnityEngine.UI.LayoutElement>();
             sLe.preferredWidth = 50; sLe.preferredHeight = 50;
        }

        GameObject txtObj = new GameObject("Info");
        txtObj.transform.SetParent(item.transform, false);
        var txt = txtObj.AddComponent<TMPro.TextMeshProUGUI>();
        txt.text = $"{i+1}. {name}   -   {score:N0}";
        txt.fontSize = 32;
        txt.alignment = TMPro.TextAlignmentOptions.Left;
        txt.color = (i < 3) ? Color.yellow : Color.white;
        var tLe = txtObj.AddComponent<UnityEngine.UI.LayoutElement>();
        tLe.preferredWidth = 600; tLe.preferredHeight = 50;
    }

    private void PopulateShop(GameObject panel)
    {
        Debug.Log("[Lobby] Populating Shop UI...");

        foreach (Transform child in panel.transform) Destroy(child.gameObject);

        // 1. Background
        var bgImg = panel.GetComponent<UnityEngine.UI.Image>();
        if (bgImg == null) bgImg = panel.AddComponent<UnityEngine.UI.Image>();
        bgImg.color = new Color(0.1f, 0.1f, 0.2f, 0.95f);

        // 2. Title
        GameObject titleObj = new GameObject("Title");
        titleObj.transform.SetParent(panel.transform, false);
        var titleTxt = titleObj.AddComponent<TMPro.TextMeshProUGUI>();
        titleTxt.text = "ITEM SHOP";
        titleTxt.fontSize = 48;
        titleTxt.fontStyle = TMPro.FontStyles.Bold;
        titleTxt.alignment = TMPro.TextAlignmentOptions.Center;
        titleTxt.color = new Color(1f, 0.8f, 0.2f); // Gold
        
        RectTransform titleRt = titleObj.GetComponent<RectTransform>();
        titleRt.anchorMin = new Vector2(0, 0.85f); titleRt.anchorMax = new Vector2(1, 0.95f);
        titleRt.offsetMin = Vector2.zero; titleRt.offsetMax = Vector2.zero;

        // [NEW] Charge Coin Button (Top Right)
        GameObject chargeBtnObj = new GameObject("Btn_Charge");
        chargeBtnObj.transform.SetParent(panel.transform, false);
        var chargeImg = chargeBtnObj.AddComponent<UnityEngine.UI.Image>();
        chargeImg.color = new Color(0, 0.7f, 0.3f); // Green
        var chargeBtn = chargeBtnObj.AddComponent<UnityEngine.UI.Button>();
        
        var chargeTxtObj = new GameObject("Text");
        chargeTxtObj.transform.SetParent(chargeBtnObj.transform, false);
        var chargeTxt = chargeTxtObj.AddComponent<TMPro.TextMeshProUGUI>();
        chargeTxt.text = "CHARGE COINS";
        chargeTxt.fontSize = 24;
        chargeTxt.alignment = TMPro.TextAlignmentOptions.Center;
        chargeTxt.color = Color.white;
        
        RectTransform chargeRt = chargeBtnObj.GetComponent<RectTransform>();
        chargeRt.anchorMin = new Vector2(0.75f, 0.85f); chargeRt.anchorMax = new Vector2(0.95f, 0.92f);
        chargeRt.offsetMin = Vector2.zero; chargeRt.offsetMax = Vector2.zero;

        chargeBtn.onClick.AddListener(() => {
            string shopUrl = "https://rhythm-game-frontend.vercel.app/shop";
            Debug.Log($"[Shop] Redirecting to Charge Page: {shopUrl}");
            Application.OpenURL(shopUrl);
        });

        // 3. User Coin Display
        GameObject coinObj = new GameObject("CoinDisplay");
        coinObj.transform.SetParent(panel.transform, false);
        var coinTxt = coinObj.AddComponent<TMPro.TextMeshProUGUI>();
        coinTxt.text = "Loading...";
        coinTxt.fontSize = 32;
        coinTxt.alignment = TMPro.TextAlignmentOptions.Right;
        coinTxt.color = Color.yellow;
        RectTransform coinRt = coinObj.GetComponent<RectTransform>();
        coinRt.anchorMin = new Vector2(0.6f, 0.85f); coinRt.anchorMax = new Vector2(0.95f, 0.95f);
        coinRt.offsetMin = Vector2.zero; coinRt.offsetMax = Vector2.zero;

        // 4. Content Area
        GameObject scrollObj = new GameObject("ScrollArea");
        scrollObj.transform.SetParent(panel.transform, false);
        var scrollRt = scrollObj.AddComponent<RectTransform>();
        scrollRt.anchorMin = new Vector2(0.05f, 0.1f); scrollRt.anchorMax = new Vector2(0.95f, 0.8f);
        scrollRt.offsetMin = Vector2.zero; scrollRt.offsetMax = Vector2.zero;
        
        var scroll = scrollObj.AddComponent<UnityEngine.UI.ScrollRect>();
        GameObject content = new GameObject("Content");
        content.transform.SetParent(scrollObj.transform, false);
        
        var grid = content.AddComponent<UnityEngine.UI.GridLayoutGroup>();
        grid.cellSize = new Vector2(250, 300);
        grid.spacing = new Vector2(30, 30);
        grid.padding = new RectOffset(30,30,30,30);
        grid.constraint = UnityEngine.UI.GridLayoutGroup.Constraint.FixedColumnCount;
        grid.constraintCount = 3;
        
        var csf = content.AddComponent<UnityEngine.UI.ContentSizeFitter>();
        csf.verticalFit = UnityEngine.UI.ContentSizeFitter.FitMode.PreferredSize;
        
        scroll.content = content.GetComponent<RectTransform>();
        scroll.vertical = true; scroll.horizontal = false;
        
        // Viewport
        GameObject viewport = new GameObject("Viewport");
        viewport.transform.SetParent(scrollObj.transform, false);
        viewport.AddComponent<UnityEngine.UI.Mask>();
        viewport.AddComponent<UnityEngine.UI.Image>().color = new Color(1,1,1,0.1f);
        var vpRt = viewport.GetComponent<RectTransform>();
        vpRt.anchorMin = Vector2.zero; vpRt.anchorMax = Vector2.one;
        vpRt.offsetMin = Vector2.zero; vpRt.offsetMax = Vector2.zero;
        content.transform.SetParent(viewport.transform, false);
        scroll.viewport = vpRt;

        // Close Button
        BindCloseButton(panel);

        // Fetch User Data & Populate Items
        if (NetworkManager.Instance != null)
        {
            NetworkManager.Instance.GetUserProfile((profile) => {
                if (profile != null)
                {
                    coinTxt.text = $"COINS: {profile.coins:N0}";
                    CreateShopItems(content.transform, profile);
                }
                else
                {
                    coinTxt.text = "Login Required";
                    CreateShopItems(content.transform, null); // Show items but disable buy
                }
            });
        }
        else
        {
             coinTxt.text = "Offline";
             CreateShopItems(content.transform, null);
        }
    }

    private void CreateShopItems(Transform content, UserProfile profile)
    {
        // Define Shop Items (Mock or Static List for now)
        var items = new [] {
            new { id="song_pack_1", name="K-Pop Pack 1", price=2000, desc="Unlock 3 Popular Songs" },
            new { id="skin_neon", name="Neon Avatar", price=5000, desc="Glow in the dark!" },
            new { id="effect_star", name="Star Notes", price=1500, desc="Shiny star hit effects" },
            new { id="pet_robo", name="Robo Pet", price=8000, desc="A cute robot companion" }
        };

        foreach(var item in items)
        {
            GameObject card = new GameObject($"Item_{item.id}");
            card.transform.SetParent(content, false);
            var cardImg = card.AddComponent<UnityEngine.UI.Image>();
            cardImg.color = new Color(0.2f, 0.2f, 0.3f);
            
            // Name
            GameObject nameObj = new GameObject("Name");
            nameObj.transform.SetParent(card.transform, false);
            var nTxt = nameObj.AddComponent<TMPro.TextMeshProUGUI>();
            nTxt.text = item.name;
            nTxt.fontSize = 24; nTxt.alignment = TMPro.TextAlignmentOptions.Center;
            RectTransform nRt = nameObj.GetComponent<RectTransform>();
            nRt.anchorMin = new Vector2(0, 0.7f); nRt.anchorMax = new Vector2(1, 0.9f);
            nRt.offsetMin = Vector2.zero; nRt.offsetMax = Vector2.zero;
            
            // Price
            GameObject pObj = new GameObject("Price");
            pObj.transform.SetParent(card.transform, false);
            var pTxt = pObj.AddComponent<TMPro.TextMeshProUGUI>();
            pTxt.text = $"{item.price:N0} G";
            pTxt.fontSize = 32; pTxt.alignment = TMPro.TextAlignmentOptions.Center;
            pTxt.color = Color.yellow;
            RectTransform pRt = pObj.GetComponent<RectTransform>();
            pRt.anchorMin = new Vector2(0, 0.4f); pRt.anchorMax = new Vector2(1, 0.6f);
            pRt.offsetMin = Vector2.zero; pRt.offsetMax = Vector2.zero;

            // Buy Button
            GameObject btnObj = new GameObject("Btn_Buy");
            btnObj.transform.SetParent(card.transform, false);
            var bImg = btnObj.AddComponent<UnityEngine.UI.Image>();
            var btn = btnObj.AddComponent<UnityEngine.UI.Button>();
            
            GameObject bTxtObj = new GameObject("Text");
            bTxtObj.transform.SetParent(btnObj.transform, false);
            var bTxt = bTxtObj.AddComponent<TMPro.TextMeshProUGUI>();
            bTxt.fontSize = 20; bTxt.alignment = TMPro.TextAlignmentOptions.Center;
            bTxt.color = Color.black;

            RectTransform bRt = btnObj.GetComponent<RectTransform>();
            bRt.anchorMin = new Vector2(0.1f, 0.05f); bRt.anchorMax = new Vector2(0.9f, 0.25f);
            bRt.offsetMin = Vector2.zero; bRt.offsetMax = Vector2.zero;
            bRt.sizeDelta = Vector2.zero; // Force stretch

            // State Logic
            bool isOwned = false;
            if (profile != null && profile.inventory != null)
            {
                isOwned = System.Array.Exists(profile.inventory, x => x == item.id);
            }

            if (isOwned)
            {
                bImg.color = Color.gray;
                bTxt.text = "OWNED";
                btn.interactable = false;
            }
            else if (profile != null && profile.coins >= item.price)
            {
                bImg.color = Color.green;
                bTxt.text = "BUY";
                btn.onClick.AddListener(() => {
                    // Pre-optimistic update
                    btn.interactable = false;
                    bTxt.text = "Buying...";
                    
                    int newCoins = profile.coins - item.price;
                    var newInvList = new System.Collections.Generic.List<string>(profile.inventory ?? new string[0]);
                    newInvList.Add(item.id);
                    
                    NetworkManager.Instance.UpdateUserShop(newCoins, newInvList.ToArray(), (success) => {
                        if (success)
                        {
                            // Refresh Panel
                            PopulateShop(card.transform.parent.parent.parent.parent.transform.parent.gameObject); 
                            // Hack fix: finding shopPanel via hierarchy is messy.
                            // Better to just call OnShopClick() which calls TogglePanel(shopPanel) which calls PopulateShop(shopPanel)
                            // But CreateShopItems is inside the class so we can access shopPanel via 'Instance' or direct.
                            // Since this is inside SchoolLobbyManager, we can just access 'shopPanel' member.
                        }
                        else
                        {
                            bTxt.text = "Error";
                            btn.interactable = true;
                        }
                    });
                });
            }
            else
            {
                bImg.color = new Color(0.5f, 0, 0);
                bTxt.text = "NO COINS";
                btn.interactable = false;
            }
        }
    }

    // [NEW] Helper for Parsing JSON Arrays
    public static class JsonHelper
    {
        public static T[] FromJson<T>(string json)
        {
            string newJson = "{ \"array\": " + json + "}";
            Wrapper<T> wrapper = JsonUtility.FromJson<Wrapper<T>>(newJson);
            return wrapper.array;
        }

        [System.Serializable]
        private class Wrapper<T>
        {
            public T[] array;
        }
    }

    [System.Serializable]
    public class RankEntry
    {
        public int id;
        public string username;
        public int score;
        public string created_at;
    }
}

